[{
    "id": "preferences",
    "children": [
        {
            "id": "package-settings",
            "children": [
                {
                    "caption": "PowerShell",
                    "children": [
                        {
                            "caption": "Settings",
                            "id": "powershell-settings",
                            "command": "edit_settings",
                            "args": {
                                "base_file": "${packages}/PowerShell/PowerShell.sublime-settings",
                                "default": "/* See the left pane for the list of settings and valid values. */\n{\n\t$0\n}\n",
                            },
                        },
                        {
                            "caption": "Key Bindings",
                            "id": "powershell-keymap",
                            "command": "edit_settings",
                            "args": {
                                "base_file": "${packages}/PowerShell/Default.sublime-keymap",
                                "default": "/* See the left pane for the shipped keybindings. */\n[\n\t$0\n]\n",
                            },
                        },
                    ]
                },
            ]
        },
    ]
}]
